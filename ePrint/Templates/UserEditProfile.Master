    <style type="text/css">
        #accordion ul li:hover
        {
            background-color: #D3D3D3;
            cursor: pointer;
            border-radius: 5px;
        }

        #accordion ul li ul:hover
        {
            background-color: White;
            cursor: pointer; /*border-radius: 5px;*/
