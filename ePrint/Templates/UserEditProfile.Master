<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="UserEditProfile.master.cs" Inherits="ePrint.Templates.UserEditProfile" %>

<%@ Register TagPrefix="telerik" Namespace="Telerik.Web.UI" Assembly="Telerik.Web.UI" %>
<%@ Register TagPrefix="crm" TagName="headerUC" Src="~/Templates/header.ascx" %>
<%@ Register TagPrefix="crm" TagName="lowerheaderUC" Src="~/Templates/lowerheader.ascx" %>
<%@ Register TagPrefix="crm" TagName="callclass" Src="~/usercontrol/CallClass.ascx" %>

<script runat="server">
    protected override void OnLoad(EventArgs e)
    {
        base.OnLoad(e);
        if (this.ltrHeadAssets != null && string.IsNullOrEmpty(this.ltrHeadAssets.Text))
        {
            string vn = this.VersionNumber ?? string.Empty;
            string sOpen = "<scr" + "ipt";
            string sClose = "</scr" + "ipt>";
            System.Text.StringBuilder sb = new System.Text.StringBuilder(512);
            sb.Append(sOpen).Append(" type=\"text/javascript\" src=\"../js/jquery.min.js?VN='").Append(vn).Append("'\">").Append(sClose);
            sb.Append(sOpen).Append(" type=\"text/javascript\" src=\"../js/jquery.popup.js?VN='").Append(vn).Append("'\">").Append(sClose);
            sb.Append(sOpen).Append(" type=\"text/javascript\" language=\"javascript\" src=\"../js/animation.js?VN='").Append(vn).Append("'\">").Append(sClose);
            sb.Append(sOpen).Append(" type=\"text/javascript\" language=\"javascript\" src=\"../js/commonloading.js?VN='").Append(vn).Append("'\">").Append(sClose);
            sb.Append(sOpen).Append(" type=\"text/javascript\" language=\"javascript\" src=\"../js/jquery-1.3.2.js?VN='").Append(vn).Append("'\">").Append(sClose);
            this.ltrHeadAssets.Text = sb.ToString();
        }
    }
</script>

