<body>
    <form id="form1" runat="server">
        <telerik:RadScriptManager ID="ScriptManager2" runat="server" EnablePartialRendering="true"
            EnablePageMethods="true">
        </telerik:RadScriptManager>
        <asp:PlaceHolder ID="plhStyle" runat="server"></asp:PlaceHolder>
        <asp:HiddenField ID="hdnGetCookiesValue" runat="server" Value='' />
        <asp:HiddenField ID="hdngetparticularLIid" runat="server" Value='' />
        <table id="outerTable" cellpadding="0" cellspacing="0" border="0" style="width: 100%;"
            align="center">
            <!--HEADER-->
            <tr class="SrchResHeight">
                <td>
                    <div align="left" id="maindivstyle">
                        <crm:callclass runat="server" ID="callsettings" />
                        <div id="settingclass" style="display: none">
                            <asp:PlaceHolder runat="server" ID="plclass"></asp:PlaceHolder>
                        </div>
                    </div>
                    <div align="left">
                        <asp:PlaceHolder ID="plhHeader" EnableViewState="false" runat="server"></asp:PlaceHolder>
                    </div>
                </td>
            </tr>
            <tr>
                <td>
                    <table cellspacing="0" cellpadding="0" width="100%" border="0">
                        <!-- Navigation -->
                        <crm:headerUC ID="header1" EnableViewState="false" runat="server"></crm:headerUC>
                        <tr>
                            <td>
                                <table cellpadding="0" cellspacing="0" width="100%">
                                    <tr valign="top">
                                        <td style="width: 100%; background-color: white" align="center">
                                            <table width="100%" cellspacing="0" cellpadding="0">
                                                <tr>
                                                    <td>
                                                        <table id="middleTable" cellspacing="0" cellpadding="0" width="100%" border="0" style="background-color: white">
                                                            <crm:lowerheaderUC ID="header2" runat="server"></crm:lowerheaderUC>
                                                            <!--navigator end -->
                                                            <tr>
                                                                <td>
                                                                    <table cellpadding="0" cellspacing="0" width="100%" border="0" class="">
                                                                        <%--border_leftonly borderright--%>
                                                                        <tr valign="top">
                                                                            <td>
                                                                                <div class="onlyEmpty">
                                                                                    <img src="<%=strImagepath%>nil.gif" width="1" border="0" height="10px" alt="" />
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                        <tr valign="top">
                                                                            <td class="bodypanel" align="center" style="background-color: White">
                                                                                <table style="width: 100%" id="innerTable" border="0" cellpadding="0" cellspacing="0">
                                                                                    <tr valign="top">
                                                                                        <!--LEFTPANEL-->
                                                                                        <td width="175px" align="left" style="padding-left: 1px;">
                                                                                            <table cellpadding="0" cellspacing="0" border="0" width="100%">
                                                                                                <tr style="display: block;">
                                                                                                    <td align="left">
                                                                                                        <%--Original Menu--%>
                                                                                                        <div id="divsetting" style="height: auto;" runat="server">
                                                                                                            <div class="setting_eprint_title">
                                                                                                                <asp:Label ID="lbltxt" runat="server" Text="" CssClass="eprint_mis13px"></asp:Label>
                                                                                                            </div>
                                                                                                            <div class="setting_divtop">
                                                                                                                <ul class="accordion setting_accordiondiv" id="accordion">
                                                                                                                    <li id="li2" class="setting_marginleft25px">
                                                                                                                        <h1 id="h1EditProfile" class="setting_font12px">
                                                                                                                            <asp:Label ID="lblEditProfile" runat="server">&nbsp;&nbsp;<%=objLanguage.GetLanguageConversion("User_Setting")%></asp:Label>                                                                                                                            
                                                                                                                        </h1>
                                                                                                                        <ul id="ul2" class="setting_ulpadding3px">
                                                                                                                            <li id="li24" runat="server" class="setting_panellitxt">
                                                                                                                                <a href="<%=strSitepath %>Settings/user_edit.aspx" class="anchor_fontsize"
                                                                                                                                    style="color: Black">&nbsp;<%=objLanguage.GetLanguageConversion("User_Profile")%></a></li>
                                                                                                                            <li id="li23" runat="server" class="setting_panellitxt">
                                                                                                                                <a href="<%=strSitepath %>Settings/change_password.aspx" class="anchor_fontsize"
                                                                                                                                    style="color: Black">&nbsp<%=objLanguage.GetLanguageConversion("Change_Password")%></a></li>
                                                                                                                            <li id="li22" runat="server" class="setting_panellitxt">
                                                                                                                                <a href="<%=strSitepath %>Settings/alert_settings.aspx" class="anchor_fontsize" style="color: Black">&nbsp;<%=objLanguage.GetLanguageConversion("TaskCall_Alert_Settings")%></a></li>                                                                                                                            
                                                                                                                        </ul>
                                                                                                                    </li>
                                                                                                                  
                                                                                                                    <asp:PlaceHolder ID="PlaceHolder1" runat="server"></asp:PlaceHolder>
                                                                                                                    
                                                                                                                </ul>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </td>
                                                                                                </tr>
                                                                                            </table>
                                                                                        </td>
                                                                                        <td style="width: 15px;">
                                                                                            <img src="<%=strImagepath%>nil.gif" border="0" style="width: 15px;" alt="" />&nbsp;
                                                                                        </td>
                                                                                        <!--BODY TD START-->
                                                                                        <td valign="top" style="width: 90%; height: 100%; padding-left: 10px;">
                                                                                            <table class="Tb_BGcolor" style="height: 100%" cellspacing="0" cellpadding="0" border="0"
                                                                                                width="100%" align="right">
                                                                                                <tr>
                                                                                                    <td valign="top">
                                                                                                        <asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server">
                                                                                                        </asp:ContentPlaceHolder>
                                                                                                    </td>
                                                                                                </tr>
                                                                                            </table>
                                                                                        </td>
                                                                                        <!--BODY TD END-->
                                                                                    </tr>
                                                                                </table>
