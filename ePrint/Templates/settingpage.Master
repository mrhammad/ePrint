    <script type="text/javascript" language="javascript" src="../js/jquery-1.3.2.js?VN='<%#VersionNumber%>'"></script>
    <script type="text/javascript">
        var menuids = new Array("verticalmenu", "webverticalmenu") //Enter id(s) of UL menus, separated by commas                
        var submenuoffset = -2 //Offset of submenus from main menu. Default is -2 pixels.
        var storeActive = '';
        var storeDeactive = '';
        function createcssmenu() {
            for (var i = 0; i < menuids.length; i++) {
                if (document.getElementById(menuids[i]) != null) {  //IE, object's null value condition, on 26.09.2011
                    var ultags = document.getElementById(menuids[i]).getElementsByTagName("ul")
                    for (var t = 0; t < ultags.length; t++) {

                        var spanref = document.createElement("span")
                        spanref.className = "arrowdiv"
                        spanref.innerHTML = "&nbsp;&nbsp;"
                        ultags[t].parentNode.getElementsByTagName("a")[0].appendChild(spanref)

                        ultags[t].parentNode.onmouseover = function () {
                            var pare = document.getElementById("verticalmenu1");
                            var chil = pare.getElementsByTagName("li");

                            var submenuoffset1 = 32;
                            var inneroffset = 190;
                            if (navigator.appName == 'Microsoft Internet Explorer') {
                                submenuoffset1 = 31;
                                inneroffset = 189;
                            }

                            this.getElementsByTagName("ul")[0].style.left = this.parentNode.offsetWidth + submenuoffset + "px"
                            var innid1 = this.getElementsByTagName("ul")[0].id;
                            this.getElementsByTagName("ul")[0].style.display = "block"
                            //setTimeout("submenuon('"+innid1+"')",1000);

                        }
                        ultags[t].parentNode.onmouseout = function () {
                            var innid = this.getElementsByTagName("ul")[0].id;
                            //submenuoff(innid);
                            //setTimeout("submenuoff('"+innid+"')",1000);
                            this.getElementsByTagName("ul")[0].style.display = "none";
                            //TestOut(this.getElementsByTagName("ul")[0]);

                        }
                    }
                }
            }
        }
        function TestOut(tes) {
            //alert("storeDeactive: "+storeDeactive);
            //alert("storeActive: "+storeActive);
            tes.style.display = "none";

        }
        function submenuoff(type) {
            //alert(type);
            document.getElementById(type).style.display = "none";
        }
        function submenuon(type) {
            //alert(type);
            document.getElementById(type).style.display = "block";
        }

        if (window.addEventListener)
            window.addEventListener("load", createcssmenu, false)
        else if (window.attachEvent)
            window.attachEvent("onload", createcssmenu)
    </script>
    <script language="javascript" type="text/javascript">
        function settingstatus() {
            if (status == 'none') {
                slideup('ctl00_divsetting');
                document.getElementById('ctl00_setting1').style.display = 'none';
                document.getElementById('ctl00_ul9').style.display = 'block';
            }
            else {
                slidedown('ctl00_divsetting');
                document.getElementById('ctl00_setting1').style.display = 'block';
                document.getElementById('ctl00_showsetting1').style.display = 'none';
            }
        }

        function settingstatus_Webstore(status) {

            if (status == 'none') {
                slideup('ctl00_div_WebstoreContent');
                document.getElementById('ctl00_divHeaderShow').style.display = 'none';
                document.getElementById('ctl00_divHeaderHide').style.display = 'block';
            }
            else {
                slidedown('ctl00_div_WebstoreContent');
                document.getElementById('ctl00_divHeaderShow').style.display = 'block';
                document.getElementById('ctl00_divHeaderHide').style.display = 'none';
            }
        }
        function applystyle(val) {
            if (val == 'v') {
                document.getElementById('ctl00_divsetting').style.overflow = 'visible';
            }
            else {
                document.getElementById('ctl00_divsetting').style.overflow = 'hidden';
            }
        }
        function setwidth() {
            if (navigator.appName == 'Microsoft Internet Explorer') {
                document.getElementById("settingclass").style.display = "block";
            }
            else {
                var d = document.getElementById('maindivstyle');
                var olddiv = document.getElementById("settingclass");
                d.removeChild(olddiv);
            }
        }
    </script>
    <style type="text/css">
        #accordion ul li:hover {
            background-color: #D3D3D3;
            cursor: pointer;
            border-radius: 5px;
        }

        #accordion ul li ul:hover {
            background-color: White;
            cursor: pointer; /*border-radius: 5px;*/
            width: 100px;
        }

        #accordion h1 a .ui-icon {
            float: right;
        }
    </style>
    <script type="text/javascript">

        function ItemSelected(ID, li) {
            //  alert(ID+ " _ "+ li);    
            //document.cookie = "MainTabSelect=" + ID;
            //document.cookie = "SubTabSelect=" + li;

            /Store in session/
            sessionStorage.setItem("MainTab", ID);
            sessionStorage.setItem("SubTab", li);
        }


        function ReadCookie(CookieName) {
            var cookieStr = document.cookie;
            if (cookieStr.indexOf(CookieName) > -1) {
                var t = cookieStr.split(';');
                for (var j = 0; j < t.length; j++) {

                    if (t[j].indexOf(CookieName) > -1) {
                        var n = t[j].split('=');
                        var selectedItem = n[1];
                        return selectedItem;
                    }
                }
            }
            return "";
        }

        function getcookiesvalue() {

            debugger;
            var hdnGetCookiesValue = document.getElementById("ctl00_hdnGetCookiesValue");
            var hdngetparticularLIid = document.getElementById("ctl00_hdngetparticularLIid");

            hdnGetCookiesValue.value = sessionStorage.getItem('MainTab');//ReadCookie('MainTabSelect');
            hdngetparticularLIid.value = sessionStorage.getItem('SubTab');//ReadCookie('SubTabSelect');


            var imgup1 = document.getElementById("ctl00_imgup1");
            var imgUp2 = document.getElementById("ctl00_imgUp2");
            var imgUp3 = document.getElementById("ctl00_imgUp3");
            var imgUp33 = document.getElementById("ctl00_imgUp33");
            var imgUp4 = document.getElementById("ctl00_imgUp4");
            var imgUp5 = document.getElementById("ctl00_imgUp5");
            var imgUp6 = document.getElementById("ctl00_imgUp6");
            var imgUp7 = document.getElementById("ctl00_imgUp7");
            var imgUp8 = document.getElementById("ctl00_imgUp8");
            var imgUp9 = document.getElementById("ctl00_imgUp9");
            var imgUp10 = document.getElementById("ctl00_imgUp10");
            var imgUp11 = document.getElementById("ctl00_imgUp11");
            var imgUp12 = document.getElementById("ctl00_imgUp12");
            var imgUp13 = document.getElementById("ctl00_imgUp13");
            var imgUpProofs = document.getElementById("ctl00_imgUpProofs");


            if (hdnGetCookiesValue != null) {

                $('ul#accordion > li > ul').hide();
                $('#' + hdnGetCookiesValue.value).show();


                if (hdnGetCookiesValue.value == "ul9") {
                    $(".one").toggle('down');
                    imgup1.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ul2") {
                    $(".two").toggle();
                    imgUp2.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ul8") {
                    $(".three").toggle();
                    imgUp3.style.display = 'none';
                }

                if (hdnGetCookiesValue.value == "ul66") {
                    $(".four1").toggle();
                    imgUp33.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ul6") {
                    $(".four").toggle();
                    imgUp4.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ul7") {
                    $(".five").toggle();
                    imgUp5.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ul4") {
                    $(".six").toggle();
                    imgUp6.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ul1") {
                    $(".seven").toggle();
                    imgUp7.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ulothercost") {
                    $(".eight").toggle();
                    imgUp8.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "verticalmenu1") {
                    $(".nine").toggle();
                    imgUp9.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ulprocessflow") {
                    $(".ten").toggle();
                    imgUp10.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "Ul3") {
                    $(".eleven").toggle();
                    imgUp11.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "UlProofs") {
                    $(".fourteen").toggle();
                    imgUpProofs.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ultemplates") {
                    $(".twelve").toggle();
                    imgUp12.style.display = 'none';
                }
                if (hdnGetCookiesValue.value == "ulinventory") {
                    $(".thirteen").toggle();
                    imgUp13.style.display = 'none';
                }

                if (hdngetparticularLIid.value == 'ctl00_li5' || hdngetparticularLIid.value == 'ctl00_li6' || hdngetparticularLIid.value == 'ctl00_li15') {
                    $('#' + hdngetparticularLIid.value).addClass("settingonmouseverselectedcompany");
                }
                else {
                    $('#' + hdngetparticularLIid.value).addClass("settingonmouseverselected");
                }
            }
        }

        $(document).ready(function () {

            // initialise
            $('ul#accordion > li > ul').hide();

            $('#h1accounting').click(function () {

                $(".one").toggle();
                $("#ul9").slideUp();
            });
            $('#h1appearance').click(function () {
                $(".two").toggle();
                $("#ul2").slideUp();
            });
            $('#h1company').click(function () {
                $(".three").toggle();
                $("#ul8").slideUp();
            });

            $('#stripe_heading').click(function () {
                debugger;
                $(".four1").toggle();
                $("#ul66").slideUp();
            });

            $('#h1contentmgmt').click(function () {
                $(".four").toggle();
                $("#ul6").slideUp();
            });
            $('#h1crm').click(function () {
                $(".five").toggle();
                $("#ul7").slideUp();
            });
            $('#h1systememails').click(function () {
                $(".six").toggle();
                $("#ul4").slideUp();
            });
            $('#h1general').click(function () {
                $(".seven").toggle();
                $("#ul1").slideUp();
            });
            $('#h1othercost').click(function () {
                $(".eight").toggle();
                $("#ulothercost").slideUp();
            });
            $('#h1plantprocess').click(function () {
                $(".nine").toggle();
                $("#verticalmenu1").slideUp();
            });
            $('#h1processflow').click(function () {
                $(".ten").toggle();
                $("#ulprocessflow").slideUp();
            });
            $('#h1warehousereport').click(function () {
                $(".eleven").toggle();
                $("#Ul3").slideUp();
            });
            $('#h1Proofing').click(function () {
                $(".fourteen").toggle();
                $("#UlProofs").slideUp();
            });

            $('#h1templates').click(function () {
                $(".twelve").toggle();
                $("#ultemplates").slideUp();
            });
            $('#h1inventory').click(function () {
                $(".thirteen").toggle();
                $("#ulinventory").slideUp();
            });


            $('ul#accordion > li > h1').click(function () {
                if ($(this).next().css('display') == 'none') {
                    $('ul#accordion > li > ul').slideUp();
                    $(this).next().slideDown();
                }
            });
            //var url = window.location.pathname;
            //if (url == "/settings/settings.aspx") {
            //    sessionStorage.setItem("MainTab", "");
            //    sessionStorage.setItem("SubTab", "");
            //    window.sessionStorage.clear();
            //}
            //if (url != "settings/settings.aspx") {
            getcookiesvalue();
            //}
            //document.cookie = "MainTabSelect=; expires=Thu, 01 Jan 1970 00:00:00 UTC";
            //document.cookie = "SubTabSelect=; expires=Thu, 01 Jan 1970 00:00:00 UTC";

        });

    </script>
</head>
